# AgentRAG Configuration

# LLM (OpenAI-compatible API for chat/reasoning)
AGENTRAG_API_KEY=sk-your-chat-api-key
AGENTRAG_API_BASE=https://api.deepseek.com/v1

# Embedding (can use a different provider)
AGENTRAG_EMBEDDING_API_KEY=sk-your-embedding-api-key
AGENTRAG_EMBEDDING_API_BASE=https://api.openai.com/v1

# Models
AGENTRAG_MODEL=deepseek-chat
AGENTRAG_EMBEDDING_MODEL=text-embedding-3-large

# Vector store ("local" = Qdrant local, "remote" = Qdrant Cloud/server)
AGENTRAG_VECTOR_MODE=local
AGENTRAG_QDRANT_URL=
AGENTRAG_QDRANT_API_KEY=

# Web search (optional — enables Tavily high-quality search)
AGENTRAG_TAVILY_API_KEY=
